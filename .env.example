# Copy to .env and fill in. .env is gitignored.

# Required: OpenRouter API key for the AI assistant (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Required for any non-local deployment: signing key for the session cookie.
# If unset, a fixed insecure development default is used - do not rely on it in production.
SESSION_SECRET=

# Optional: override the MVP login credentials (default user / password).
APP_USERNAME=
APP_PASSWORD=

# Optional: set to true when serving over TLS so the session cookie is marked Secure.
HTTPS_ONLY=
